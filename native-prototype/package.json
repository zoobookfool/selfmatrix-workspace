{
  "name": "selfmatrix-native-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "SelfMatrix native desktop prototype using Electron WebContentsView.",
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron src/main.cjs",
    "smoke": "electron src/main.cjs --smoke",
    "memory": "electron src/main.cjs --memory-probe",
    "cinny-shell": "electron src/main.cjs --cinny-shell",
    "cinny-shell-smoke": "electron src/main.cjs --cinny-shell-smoke",
    "test": "npm run smoke && npm run memory && npm run cinny-shell-smoke",
    "e2e:join": "node e2e/native-join.e2e.mjs",
    "e2e:callflow": "node e2e/native-callflow.e2e.mjs"
  },
  "devDependencies": {
    "electron": "43.0.0"
  },
  "dependencies": {
    "matrix-widget-api": "1.16.1"
  }
}
